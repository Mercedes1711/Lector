{
  "name": "lector2",
  "version": "1.0.0",
  "description": "Portal de manga y anime - Manga verso",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "node ./node_modules/tailwindcss/lib/cli.js -i style.css -o output.css --watch",
    "build": "npx tailwindcss -i ./style.css -o ./public/output.css",
    "build:min": "npx tailwindcss -i ./style.css -o ./public/output.css --minify",
    "watch": "npx tailwindcss -i ./style.css -o ./public/output.css --watch"
  },
  "keywords": [
    "manga",
    "anime",
    "lector"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ansi-regex": "^5.0.1",
    "ansi-styles": "^4.3.0",
    "anymatch": "^3.1.3",
    "baseline-browser-mapping": "^2.9.19",
    "binary-extensions": "^2.3.0",
    "braces": "^3.0.3",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001769",
    "chokidar": "^3.6.0",
    "cliui": "^8.0.1",
    "color-convert": "^2.0.1",
    "color-name": "^1.1.4",
    "dependency-graph": "^1.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.19"
  }
